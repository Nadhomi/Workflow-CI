name: glass-mlflow

conda_env: conda.yaml

entry_points:
  main:
    parameter:
      n_estimators: {type: int, default: 505}
      max_depth: {type: int, default: 37}
      dataset : {type: string, default: "glass_preprocessing.csv"}
    command: "python modelling.py {n_estimators} {max_depth} {dataset}"